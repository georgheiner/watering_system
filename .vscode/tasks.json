{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Upload OTA (giessanlage.local)",
      "type": "shell",
      "command": "~/.platformio/penv/bin/platformio",
      "args": [
        "run",
        "--environment",
        "esp32",
        "--target",
        "upload"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Monitor OTA Logs (giessanlage.local)",
      "type": "shell",
      "command": "~/.platformio/penv/bin/platformio",
      "args": [
        "device",
        "monitor",
        "--environment",
        "esp32"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
